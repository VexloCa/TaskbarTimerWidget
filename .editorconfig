root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,ps1}]
end_of_line = crlf
indent_style = space
indent_size = 4

[*.{md,yml,yaml,manifest}]
end_of_line = lf

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
